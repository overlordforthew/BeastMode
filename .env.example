# Beast Mode Backend Configuration

PORT=3000

# PostgreSQL connection (use your Coolify internal Postgres URL)
DATABASE_URL=postgresql://postgres:yourpassword@BeastMode_db:5432/postgres

# JWT Secret — CHANGE THIS IN PRODUCTION
JWT_SECRET=change-this-to-a-long-random-string

# CORS — set to your frontend domain (wildcards do not work with credentials)
CORS_ORIGIN=https://beastmode.namibarden.com

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=

# Password reset email (required in production if you want forgot-password to work)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@beastmode.app
